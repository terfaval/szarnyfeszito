# Supabase configuration for the Admin/Keltető MVP.
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key
SUPABASE_URL=https://example.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key
NEXT_PUBLIC_APP_URL=https://example.com

# Allow-listed admin email (case insensitive).
ADMIN_EMAIL=mate.fater@gmail.com

# OpenAI credentials + models
OPENAI_API_KEY=

# Text generation model selection.
AI_MODEL_TEXT=szarnyfeszito-text

# Chef recipe generation model selection.
AI_MODEL_CHEF=szarnyfeszito-chef

# D26 distribution region catalog source (default: auto; recommended: supabase for large catalogs once imported)
# - supabase: read from distribution_region_catalog_items only
# - repo: read from data/distribution-region-catalog only
# - auto: repo first, fallback to supabase
DISTRIBUTION_REGION_CATALOG_SOURCE=auto
# Optional override for repo catalogs folder (supports *.json and *.json.gz).
# DISTRIBUTION_REGION_CATALOG_REPO_DIR=data/distribution-region-catalog/v1

# Image generation configuration.
AI_MODEL_IMAGE=szarnyfeszito-image
SUPABASE_IMAGE_BUCKET=bird-images
IMAGE_PROVIDER=openai
IMAGE_STYLE_CONFIG_ID_SCIENTIFIC=scientific_v1
IMAGE_STYLE_CONFIG_ID_ICONIC=iconic_v1
# OpenAI supported sizes (as of 2026-03-11): 1024x1024, 1024x1536, 1536x1024, auto
IMAGE_SIZE=1024x1024
# Place publish hero (wide composition).
IMAGE_SIZE_PLACE_HERO=1536x1024
IMAGE_QUALITY=auto
IMAGE_ACCURACY_INPUTS=off
